# Vercel 会通过 CRON_SECRET 验证请求来自它的 Cron 触发器
CRON_SECRET=生成一个随机字符串填这里

# Intercom API
INTERCOM_ACCESS_TOKEN=你的Intercom_Access_Token

# 飞书 Webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxx

# 监控参数（可选，以下为默认值）
# INTERCOM_TAG_ID=11659240
# WINDOW_MINUTES=60
# THRESHOLD=10
